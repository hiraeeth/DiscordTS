{
	"name": "discordts",
	"version": "3.1.0",
	"type": "module",
	"main": "index.ts",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --watch index.ts",
		"build": "bun run scripts/build.ts",
		"start": "bun run dist/index.js",
		"deploy": "bun run scripts/deploy.ts",
		"shard": "bun run build && bun run scripts/shard.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "Decorator-driven Discord.js bot base.",
	"dependencies": {
		"@elysiajs/cors": "^1.4.0",
		"axios": "^1.7.2",
		"discord.js": "^14.15.3",
		"dotenv": "^17.4.2",
		"elysia": "^1.4.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"bun-types": "^1.1.20",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.7.0",
		"prettier": "^3.9.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1"
	}
}
